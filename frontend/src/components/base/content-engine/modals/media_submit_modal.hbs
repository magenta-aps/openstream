{{#> base/modal/modal
    id=id
    aria-labelledby="submitmediaLabel"
    size="modal-lg"
    overlayID=overlayID
}}
    <!-- will only be rendered when an overlayID is provided, check modal.hbs -->
    {{#*inline "overlay" }}
        <div class="spinner-border text-primary mb-2"
            role="status"
            style="width: 3rem; height: 3rem"
        >
            <span class="visually-hidden">{% trans "Loading..." %}</span>
        </div>
        <span class="fw-bold">{% trans "Uploading..." %}</span>
    {{/inline}}

    {{#*inline "header"}}
        <h5 class="submit-media-label modal-title">
            {{#if title }}
                {{title}}
            {{/if}}
        </h5>
        <button type="button"
            class="btn-close"
            data-bs-target="#mediaListModal"
            data-bs-toggle="modal"
            aria-label='{% trans "Close" %}'
        >
        </button>
    {{/inline }}

    {{#*inline "body"}}
        <form id="{{id}}-submitMediaForm" class="submit-media-form">
            <!-- Select File Section -->
            {{#if hasFileUpload}}
                <div class="file-upload-select-wrapper mb-4">
                    <label class="form-label text-muted fw-semibold mb-2">
                        <span class="material-symbols-outlined me-1" style="font-size: 1.1rem;">upload_file</span>
                        {% trans "Select File" %}
                    </label>
                    <div>
                        <input type="file"
                                class="media-file-input form-control form-control-lg"
                                placeholder='{% trans "Select files" %}'
                                accept=".pdf,.png,.jpeg,.jpg,.svg,.gif,.mp4,.webp,.webm"
                                name="file"
                                autocomplete="off"
                                multiple />
                    </div>
                    <small class="form-text text-muted mt-1" id="acceptedFileTypesLabel">
                        {% trans "Accepted types: PNG, JPEG, JPG, SVG, PDF, GIF, WebP, MP4, WebM" %}
                    </small>
                    <small class="form-text text-muted d-block">{% trans "It's possible to upload multiple files at once" %}</small>
                    <!-- Selected Files Display -->
                    {{#if hasFileUpload}}
                        <div class="selected-files-container mt-3 d-none">
                            <label class="form-label text-muted fw-semibold mb-2">
                                <span class="material-symbols-outlined me-1" style="font-size: 1.1rem;">description</span>
                                {% trans "Selected Files" %}
                            </label>
                            <div class="selected-files-list"></div>
                        </div>
                    {{/if}}
                </div>
                <hr class="file-upload-separator" class="my-4">
            {{/if}}
            <!-- File Name Section -->
            <div class="mb-4">
                <label class="form-label text-muted fw-semibold">
                    <span class="material-symbols-outlined me-1" style="font-size: 1.1rem;">edit</span>
                    {% trans "File Name" %}
                </label>
                <div class="form-floating position-relative w-100">
                    <input type="text"
                        id="{{id}}-fileNameInput"
                        class="file-name-input form-control form-control-lg pe-5"
                        placeholder='{% trans "File name" %}'
                        name="title"
                        data-bs-toggle="tooltip"
                        data-bs-placement="top"
                        title='{% trans "Unable to modify file names when uploading multiple files at once" %}' />
                    <span class="file-extension-display position-absolute top-50 end-0 translate-middle-y me-3 text-muted user-select-none"></span>
                    <label for="{{id}}-fileNameInput">{% trans "Enter file name" %}</label>
                </div>
            </div>
            <hr class="my-4">
            <!-- Tags Section -->
            <div class="mb-4">
                <label class="form-label text-muted fw-semibold">
                    <span class="material-symbols-outlined me-1" style="font-size: 1.1rem;">sell</span>
                    {% trans "Tags" %}
                </label>
                <div class="media-edit-tags-select dropdown-start"></div>
                <div class="selected-tags-container mt-2 d-flex gap-2 "></div>
            </div>
            <hr class="my-4">
            <!-- Category Section -->
            <div class="mb-3">
                <label class="form-label text-muted fw-semibold">
                    <span class="material-symbols-outlined me-1" style="font-size: 1.1rem;">category</span>
                    {% trans "Category" %}
                </label>
                <select
                    class="submit-media-ctg-select form-select py-2 fs-5 rounded"
                    aria-label="{% trans 'Category select' %}"
                    name="category">
                    <option value="">{% trans "Select a category..." %}</option>
                </select>
            </div>
        </form>
    {{/inline}}

    {{#*inline "footer"}}
        <button form="{{id}}-submitMediaForm" type="submit" class="save-media-btn btn btn-primary">
            <span class="material-symbols-outlined me-1">save</span>
            {% trans "Save" %}
        </button>
        <button type="button"
                class="cancel-submit-media-btn btn btn-secondary"
                data-bs-target="#mediaListModal"
                data-bs-toggle="modal">
            <span class="material-symbols-outlined me-1">cancel</span>
            {% trans "Cancel" %}
        </button>
        <button type="button" class="btn-delete-media btn btn-danger px-4 d-none">
            <span class="material-symbols-outlined me-1">delete</span>
            {% trans "Delete" %}
        </button>
    {{/inline}}
{{/base/modal/modal }}
