{{#> base/containers/html-container title="Dashboard" script-src="/src/assets/pages/emergency-slideshows/main.js" }}
{{> base/navbar/navbar_branch }}
{{#> base/containers/main-container }}

<div class="container-fluid bg-secondary-accent-lighter w-100 h-100 p-4 d-flex flex-column">
    <div class="d-flex w-100 flex-grow-1 gap-4" style="min-height: 0;">
        <div id="add-emergency-slideshow" class="w-75 h-100 bg-white p-4 d-flex flex-column border border-black overflow-hidden" style="min-height: 0;">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
                <div>
                    <p class="text-uppercase text-muted fw-semibold mb-1">Emergency Response</p>
                    <h2 class="mb-0" style="line-height: 1;">Activate Emergency Slideshow</h2>
                </div>
                <button id="activate-emergency-btn" class="btn bg-danger text-white px-4 py-2">
                    <span class="material-symbols-outlined align-middle me-1">notifications_active</span>
                    Activate
                </button>
            </div>
            <div id="emergency-feedback" class="alert alert-danger d-none" role="alert"></div>
            <div class="w-100 d-flex gap-4 flex-grow-1" style="min-height: 0;">
                <div class="select-slideshow h-100 border border-dark-gray flex-grow-1 p-3 rounded-3 bg-light d-flex flex-column overflow-hidden" style="min-height: 0;">
                    <div class="d-flex justify-content-between align-items-center flex-wrap slideshow-toolbar">
                        <h3 class="h5 mb-0">Select Slideshow</h3>
                        <div class="d-flex gap-2 flex-wrap toolbar-actions justify-content-end">
                            <button id="create-emergency-slideshow" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                                <span class="material-symbols-outlined align-middle" aria-hidden="true">add</span>
                                Create New Emergency Slideshow
                            </button>
                            <button id="refresh-slideshows" class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1">
                                <span class="material-symbols-outlined align-middle" aria-hidden="true">refresh</span>
                                Reload
                            </button>
                        </div>
                    </div>
                    <hr>
                    <div class="mb-3">
                        <label for="slideshow-search" class="form-label small text-uppercase text-muted">Quick
                            Filter</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-white">
                                <span class="material-symbols-outlined">search</span>
                            </span>
                            <input type="search" id="slideshow-search" class="form-control"
                                placeholder="Search by name or aspect ratio">
                            <button class="btn btn-outline-secondary" id="clear-slideshow-filter" type="button">
                                Clear
                            </button>
                        </div>
                    </div>
                    <div id="slideshow-list" class="slideshow-list border rounded-3 bg-white p-2 overflow-auto flex-grow-1" style="min-height: 0;">
                        <p class="text-muted text-center my-4" id="slideshow-loading-text">Loading slideshows...</p>
                        <div id="slideshow-list-items" class="d-flex flex-column gap-2"></div>
                    </div>
                </div>
                <div class="select-groups h-100 border flex-grow-1 p-3 border-dark-gray rounded-3 bg-light d-flex flex-column overflow-hidden" style="min-height: 0;">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="h5 mb-0">Select Display Groups</h3>
                        <div class="d-flex gap-2">
                            <button class="btn btn-link btn-sm text-decoration-none" id="select-all-groups">
                                Select all
                            </button>
                            <button class="btn btn-link btn-sm text-decoration-none" id="clear-all-groups">
                                Clear
                            </button>
                        </div>
                    </div>
                    <hr>
                    <label for="group-search" class="form-label small text-uppercase text-muted">Filter groups</label>
                    <div class="input-group input-group-sm mb-3">
                        <span class="input-group-text bg-white">
                            <span class="material-symbols-outlined">travel_explore</span>
                        </span>
                        <input type="search" id="group-search" class="form-control"
                            placeholder="Search by group name or aspect ratio">
                    </div>
                    <div id="display-groups-list" class="emergency-groups-list border rounded-3 bg-white p-2 overflow-auto flex-grow-1" style="min-height: 0;">
                        <p class="text-muted text-center my-4" id="groups-loading-text">Loading groups...</p>
                        <div id="groups-list-items"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="bg-white flex-grow-1 h-100 p-4 active-emergencies border border-black rounded-3 d-flex flex-column overflow-hidden" style="min-height: 0;">
            <div class="d-flex justify-content-center align-items-center flex-wrap gap-2 text-danger">
                <span class="material-symbols-outlined" aria-hidden="true">
                    warning
                </span>
                <h2 class="mb-0">Emergencies Status</h2>
                <span class="material-symbols-outlined" aria-hidden="true">
                    warning
                </span>
            </div>
            <hr>
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
                <p class="mb-0 text-muted">
                    Overview of all emergency slideshows currently configured for this branch.
                </p>
                <button id="refresh-emergencies" class="btn btn-outline-secondary btn-sm">
                    <span class="material-symbols-outlined align-middle me-1">refresh</span>
                    Refresh
                </button>
            </div>
            <div id="active-emergencies-empty" class="border rounded-3 p-4 text-center bg-light">
                <p class="mb-1 fw-semibold">No emergency slideshows</p>
                <p class="mb-0 text-muted">Activate a slideshow to override normal scheduling when critical
                    information needs to be broadcast.</p>
            </div>
            <div id="active-emergencies-list" class="d-flex flex-column gap-3 overflow-auto flex-grow-1" style="min-height: 0;"></div>
        </div>
    </div>
</div>


<div class="modal fade create-emergency-modal" id="createEmergencyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <p class="text-uppercase text-muted small mb-1">Emergency content</p>
                    <h1 class="modal-title fs-5 mb-0">Create emergency slideshow</h1>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createEmergencyForm" class="needs-validation" novalidate>
                <div class="modal-body">
                    <p class="text-muted small">Emergency slideshows will only appear in this list and are filtered from normal content.</p>
                    <div id="create-emergency-feedback" class="alert alert-danger d-none" role="alert"></div>
                    <div class="mb-3">
                        <label for="createEmergencyName" class="form-label">Name</label>
                        <input type="text" class="form-control" id="createEmergencyName" placeholder="City-wide alert" required>
                    </div>
                    <div class="row g-3">
                        <div class="col-lg-6">
                            <label for="createEmergencyCategory" class="form-label">Category</label>
                            <select id="createEmergencyCategory" class="form-select"></select>
                        </div>
                        <div class="col-lg-6">
                            <label for="createEmergencyTags" class="form-label">Tags</label>
                            <select id="createEmergencyTags" class="form-select" multiple size="5"></select>
                            <div class="form-text">Hold Ctrl (Windows) or Cmd (macOS) to select multiple tags.</div>
                        </div>
                    </div>
                    <div class="mt-4">
                        <label for="createEmergencyAspectRatio" class="form-label">Aspect ratio</label>
                        <select id="createEmergencyAspectRatio" class="form-select"></select>
                        <div class="form-text">Choose the aspect ratio that matches the displays receiving this emergency message.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="create-emergency-submit">
                        <span class="spinner-border spinner-border-sm me-2 d-none" role="status" aria-hidden="true" id="create-emergency-spinner"></span>
                        Create slideshow
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="emergencySlideshowCreatedModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5">Emergency slideshow created</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">The slideshow <strong id="createdEmergencySlideshowName"></strong> was created successfully.</p>
                <p class="text-muted mb-0">Open it in the editor to customize the layout and slides immediately.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-link" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="openEmergencySlideshowBtn">
                    <span class="material-symbols-outlined align-middle me-1" aria-hidden="true">open_in_new</span>
                    Open in editor
                </button>
            </div>
        </div>
    </div>
</div>


{{/base/containers/main-container}}
{{/base/containers/html-container}}