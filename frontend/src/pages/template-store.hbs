{{#> base/containers/html-container title="{% trans 'Template Store' %}" script-src="/src/assets/pages/template-store/main.js" }}
    {{> base/navbar/navbar_global_settings }}
    {{#> base/containers/main-container }}

        {{#> base/containers/sidebar-and-content-container pageTitle="{% trans 'Template Store' %}" }}
            {{#*inline "sidebarContent"}}
                <div class="card shadow-sm border-0">
                    <div class="card-body d-flex flex-column gap-4">
                        <div>
                            <label class="form-label small text-uppercase text-muted fw-semibold" for="template-store-search">{% trans "Search templates" %}</label>
                            <div class="position-relative">
                                <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ps-3 text-muted small">search</span>
                                <input type="search" id="template-store-search" class="form-control ps-5" placeholder="{% trans 'Search by name' %}" data-template-search autocomplete="off">
                            </div>
                        </div>

                        <div>
                            <p class="form-label small text-uppercase text-muted fw-semibold mb-2">{% trans "Aspect ratio" %}</p>
                            <div class="d-flex flex-wrap gap-2" data-template-aspect-filter>
                                <button type="button" class="btn btn-outline-primary btn-sm active" data-value="16:9">16:9</button>
                                <button type="button" class="btn btn-outline-primary btn-sm" data-value="9:16">9:16</button>
                                <button type="button" class="btn btn-outline-primary btn-sm" data-value="4:3">4:3</button>
                            </div>
                        </div>

                        <div>
                            <label for="template-store-sort" class="form-label small text-uppercase text-muted fw-semibold">{% trans "Sort by" %}</label>
                            <select id="template-store-sort" class="form-select" data-template-sort>
                                <option value="recent">{% trans "Most recently updated" %}</option>
                                <option value="oldest">{% trans "Oldest first" %}</option>
                                <option value="name">{% trans "Name A–Z" %}</option>
                            </select>
                        </div>

                        <div class="p-3 rounded bg-light border">
                            <h6 class="fw-bold text-secondary">{% trans "Need a custom layout?" %}</h6>
                            <p class="small text-muted mb-3">{% trans "Tell us what you would like to publish and we will help you craft the perfect template." %}</p>
                            <a href="mailto:support@openstream.io" class="btn btn-outline-secondary btn-sm w-100">{% trans "Contact team" %}</a>
                        </div>
                    </div>
                </div>
            {{/inline}}

            {{#*inline "mainContent"}}
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex flex-column gap-4 h-100">
                        <div class="d-flex flex-wrap justify-content-between align-items-end gap-3">
                            <div>
                                <p class="small text-uppercase text-muted fw-semibold mb-2">{% trans "Curated template library" %}</p>
                                <h2 class="h3 mb-0 text-dark">{% trans "Pick a starting point for your next screen" %}</h2>
                            </div>
                            <div class="text-end">
                                <div class="fw-semibold text-primary mb-1" data-template-summary>{% trans "Loading templates…" %}</div>
                                <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" data-template-reset>{% trans "Reset filters" %}</button>
                            </div>
                        </div>

                        <div data-template-grid aria-live="polite"></div>

                        <div class="text-center py-5 border rounded bg-light" data-template-empty hidden>
                            <h4 class="text-secondary">{% trans "No templates found" %}</h4>
                            <p class="text-muted mb-3">{% trans "Try another search term or pick a different aspect ratio." %}</p>
                            <button type="button" class="btn btn-outline-primary" data-template-reset>{% trans "Clear filters" %}</button>
                        </div>
                    </div>
                </div>
            {{/inline}}

        {{/base/containers/sidebar-and-content-container}}
    {{/base/containers/main-container}}
{{/base/containers/html-container}}