# Admin Credentials
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# Database Connection (How Keycloak talks to Postgres)
KC_DB_URL=jdbc:postgresql://openstream-db:5432/openstream_keycloak
KC_DB_USERNAME=openstream_keycloak
KC_DB_PASSWORD=openstream_keycloak

# Hostname Settings
# This tells Keycloak: "Users will talk to me via localhost"
KC_HOSTNAME=http://localhost:8080
# This tells Keycloak: "But allow other containers (like the backend) to talk to me too"
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false