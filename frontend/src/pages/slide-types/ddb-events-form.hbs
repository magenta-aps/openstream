    {{#> base/containers/html-container title="DDB Events Configuration Form" }}
    <div>
        <div class="card-body">
            <div class="mb-4">
                <label for="kommuneSelect" class="form-label mb-1">{% trans "Choose a municipality:" %}</label>
                <select required id="kommuneSelect" class="form-select border-gray">
                    <!-- Options will be populated dynamically -->
                </select>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="form-label mb-0">{% trans "Choose libraries:" %}</span>
                    <div id="librarySelectAllWrapper" class="d-flex justify-content-end align-items-center d-none">
                        <div class="form-check m-0">
                            <input class="form-check-input" type="checkbox" id="librarySelectAll" data-select-all="true" />
                            <label class="form-check-label small" for="librarySelectAll">{% trans "Select all" %}</label>
                        </div>
                    </div>
                </div>
                <div id="libraryCheckboxContainer" class="border border-gray rounded px-3 pb-1 bg-light">

                    <div id="libraryCheckboxPlaceholder" class="text-muted small">
                        {% trans "Select a municipality to load libraries." %}
                    </div>
                    <div id="libraryCheckboxGrid" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-2 mt-2"></div>
                </div>
                <small class="text-muted d-block mt-2">
                    {% trans "Select one or more libraries to include in the slide." %}</small>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="form-label mb-0">{% trans "Filter by categories:" %}</span>
                    <div id="categorySelectAllWrapper" class="d-flex justify-content-end align-items-center d-none">
                        <div class="form-check m-0">
                            <input class="form-check-input" type="checkbox" id="categorySelectAll" data-select-all="true" />
                            <label class="form-check-label small" for="categorySelectAll">{% trans "Select all" %}</label>
                        </div>
                    </div>
                </div>

                <div id="categoryCheckboxContainer" class="border border-gray rounded px-3 pb-1 bg-light">

                    <div id="categoryCheckboxPlaceholder" class="text-muted small">
                        {% trans "Select a municipality to load categories." %}</div>
                    <div id="categoryCheckboxGrid" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-2 mt-2">
                    </div>
                </div>
                <small class="text-muted d-block mt-2">
                    {% trans "Select one or more categories, or leave blank to include all." %}</small>
            </div>

            <div class="mb-4">
                <span class="form-label mb-2 d-block">{% trans "Filter by price:" %}</span>
                <div class="d-flex flex-wrap gap-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showFreeEvents" name="showFreeEvents" checked />
                        <label class="form-check-label" for="showFreeEvents">
                            {% trans "Show free events" %}
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showPaidEvents" name="showPaidEvents" checked />
                        <label class="form-check-label" for="showPaidEvents">
                            {% trans "Show paid events" %}
                        </label>
                    </div>
                </div>
                <small class="text-muted d-block mt-2">
                    {% trans "Select which types of events to include based on pricing." %}</small>
            </div>

            <div class="mb-2">
                <span class="form-label mb-2 d-block">{% trans "Events:" %}</span>
                <div class="d-flex gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="ddbEventsMode" id="ddbModeAutomatic"
                            value="automatic" checked />
                        <label class="form-check-label" for="ddbModeAutomatic">
                            {% trans "Fetch events automatically"%}</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="ddbEventsMode" id="ddbModeManual"
                            value="manual" />
                        <label class="form-check-label" for="ddbModeManual">
                            {% trans "Fetch events maunally" %}</label>
                    </div>
                    </div>
            </div>

            <div class="ms-3 mb-4" id="automaticModeFields">
                <label for="nrOfDaysInput" class="form-label mb-1">{% trans "Number of days:" %}</label>
                <input required type="number" id="nrOfDaysInput" class="form-control border-gray" min="0"
                    placeholder='{% trans "Enter number of days" %}' />
            </div>
        </div>
    </div>
    <div class="mt-2 mb-2 ms-3" id="events-preview">
        <div class="card border border-gray bg-light">
            <div class="card-body bg-light">
           
                <p class=" mb-3">
                    {% trans "The list to the left shows events based on your filters. Select events to add them to your preview." %}
                </p>
                <div class="row g-4">
                    <div class="col-12 col-xl-7">
                             <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="material-symbols-outlined" style="z-index: 2">search</span>        
                    <input type="search" id="eventSearchInput" style="padding-left: 2.3rem; position: relative; left: -2rem;" class="form-control border-gray w-100"
                        placeholder='{% trans "Search for event" %}' />
                        
                </div>
                        <div id="eventPreviewStatus" class="small mb-2"></div>
                        <ul id="eventPreviewList" class="list-group list-group-flush small"
                            style="max-height: 320px; overflow-y: auto;"></ul>
                    </div>
                    <div class="col-12 col-xl-5" id="manualSelectedEventsContainer">
                        <div class="card h-100 border border-gray">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 id="selected-events-text" class="mb-0">{% trans "Selected events" %}</h6>
                                    <small class="text-muted">{% trans "Displayed on the slide" %}</small>
                                </div>
                                <div id="manualSelectedEventsEmpty" class="text-muted small flex-shrink-0">
                                    {% trans "No events selected yet." %}</div>
                                <ul id="manualSelectedEventsList"
                                    class="list-group list-group-flush small flex-grow-1 overflow-auto mt-2"
                                    style="max-height: 320px; overflow-y: auto;"></ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
    <div class="mt-4 mb-4">
        <label for="layoutSelection" class="form-label ">{% trans "Choose layout and content:" %}</label>
        <div class="card border border-gray bg-light">
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-12 col-lg-7">
                        <div class="row g-4">
                            <!-- Vertical Option -->
                            <div class="col-sm-6 col-lg-12 col-xl-6">
                                <label class="d-block">
                                    <input id="vertical-option" type="radio" name="layout" class="d-none"
                                        value="vertical" />
                                    <div class="card border border-gray"
                                        style="cursor: pointer; aspect-ratio: 1/1; max-width: 300px;">
                                        <div class="card-body d-flex flex-column p-2">
                                            <div class="d-flex align-items-center">
                                                <input type="radio" name="layout-visual"
                                                    class="form-check-input fs-4 me-2" style="pointer-events: none;">
                                                <p class="fw-bold m-0">{% trans "Vertical: " %}</p>
                                            </div>
                                            <div class="flex-grow-1 d-flex align-items-center justify-content-center">
                                                <img src="/Hojformat-ikon.png" alt="Vertical layout" class="img-fluid"
                                                    style="max-width: 90%; max-height: 90%; object-fit: contain;" />
                                            </div>
                                        </div>
                                    </div>
                                </label>
                            </div>

                            <!-- Horizontal Option -->
                            <div class="col-sm-6 col-lg-12 col-xl-6">
                                <label class="d-block h-100">
                                    <input id="horizontal-option" type="radio" name="layout" class="d-none"
                                        value="horizontal" />
                                    <div class="card border border-gray h-100"
                                        style="cursor: pointer; aspect-ratio: 1/1; max-width: 300px;">
                                        <div class="card-body d-flex flex-column p-2">
                                            <div class="d-flex align-items-center">
                                                <input type="radio" name="layout-visual"
                                                    class="form-check-input fs-4 me-2" style="pointer-events: none;">
                                                <p class="fw-bold m-0">{% trans "Horizontal: " %}</p>
                                            </div>
                                            <div class="flex-grow-1 d-flex align-items-center justify-content-center">
                                                <img src="/Bredformat-ikon.png" alt="Horizontal layout"
                                                    class="img-fluid"
                                                    style="max-width: 90%; max-height: 90%; object-fit: contain;" />
                                            </div>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-5">
                        <label for="selectContent" class="form-label ">{% trans "Choose content:" %}</label>
                        <div class="d-flex flex-column gap-2 mt-2">
                            <div class="form-check">
                                <input class="form-check-input fs-5" type="checkbox" id="title" name="title"
                                    value="title" />
                                <label class="form-check-label " for="title">
                                    {% trans "Title" %}
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input fs-5" type="checkbox" id="subtitle" name="subtitle"
                                    value="subtitle" />
                                <label class="form-check-label " for="subtitle">
                                    {% trans "Subtitle" %}
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input fs-5" type="checkbox" id="dateTime" name="dateTime"
                                    value="dateTime" />
                                <label class="form-check-label " for="dateTime">
                                    {% trans "Date & Time" %}
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input fs-5" type="checkbox" id="description"
                                    name="description" />
                                <label class="form-check-label " for="description">
                                    {% trans "Description" %}
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input fs-5" type="checkbox" id="qrCode" name="qrCode" />
                                <label class="form-check-label " for="qrCode">
                                    {% trans "QR code" %}
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input fs-5" type="checkbox" id="location" name="location"
                                    value="location" />
                                <label class="form-check-label " for="location">
                                    {% trans "Location" %}
                                </label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input fs-5" type="checkbox" id="price" name="price"
                                    value="price" />
                                <label class="form-check-label " for="price">
                                    {% trans "Price" %}
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    

    <div class="mb-4">
        <label for="slideDurationInput" class="form-label mb-1">
            {% trans "Slide Duration (in seconds):" %}
        </label>
        <input required type="number" id="slideDurationInput" class="form-control border-gray" min="0" value="10" />
    </div>


    {{/ base/containers/html-container }}