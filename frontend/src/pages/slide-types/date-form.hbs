{{#*inline "section"}}
    <div class="mb-4">
        {{> @partial-block}}
    </div>
{{/inline}}

{{#> base/containers/html-container title="Date form" }}
    <div>
        <div class="card-body">
            {{#> section}}
               <div class="mb-2">
                   <label for="date-format-weekday-select" class="form-label">{% trans "Day of week" %}</label>

                    <select id="date-format-weekday-select" class="form-select border-gray">
                        <option value="">{% trans "Select" %}</option>
                        <option value="narrow">{% trans "Narrow" %}</option>
                        <option value="short">{% trans "Short" %}</option>
                        <option selected value="long">{% trans "Long"%}</option>
                    </select>
               </div>

               <div class="mb-2">
                    <label for="date-format-day-select" class="form-label">{% trans "Day" %}</label>

                    <select id="date-format-day-select" class="form-select border-gray">
                        <option value="">{% trans "Select" %}</option>
                        <option value="2-digit">{% trans "Two digits" %}</option>
                        <option value="numeric">{% trans "Numeric" %}</option>
                    </select>
                </div>

                <div class="mb-2">
                     <label for="date-format-month-select" class="form-label">{% trans "Month" %}</label>

                     <select id="date-format-month-select" class="form-select border-gray">
                         <option value="">{% trans "Select" %}</option>
                         <option value="2-digit">{% trans "Two digits" %}</option>
                         <option value="numeric">{% trans "Numeric" %}</option>
                         <option value="narrow">{% trans "Narrow" %}</option>
                         <option value="short">{% trans "Short" %}</option>
                         <option value="long">{% trans "Long"%}</option>
                     </select>
                 </div>
            {{/section}}

            {{#> section}}
               <select id="date-color-select" class="form-select  border-gray">
                    <option selected value="white">{% trans "White" %}</option>
                    <option value="black">{% trans "Black" %}</option>
                    <option value="red">{% trans "Red" %}</option>
                    <option value="blue">{% trans "Blue" %}</option>
                    <option value="green">{% trans "Green" %}</option>
                    <option value="yellow">{% trans "Yellow" %}</option>
                    <option value="orange">{% trans "Orange" %}</option>
                    <option value="purple">{% trans "Purple" %}</option>
                    <option value="custom">{% trans "Custom Color" %}</option>
                </select>

                <div id="date-color-picker-wrapper" class="mb- d-none">
                    <label for="date-color-picker" class="form-label ">
                        {% trans "Custom Color" %}
                    </label>
                    <div class="d-flex align-items-center gap-2">
                        <input type="color" id="date-color-picker" class="form-control form-control-color border-gray" value="#ffffff" title="Choose your custom color" />
                        <span class=" small">{% trans "Click to choose a custom color" %}</span>
                    </div>
                </div>
            {{/section}}

            {{#> section}}
                <div class="bg-gray">
                    <p id="date-format-preview"></p>
                </div>
            {{/section}}
        </div>
    </div>
{{/base/containers/html-container }}
