    <!-- HTML Wrapper -->
    {{#> base/containers/html-container title="Content Engine" script-src="/src/assets/pages/test/main.js" }}

    <!-- Main Container -->
    <div class="h-100 w-100">
        <form id="form_test">
         {{> base/form/label for="multiSelectDropdownToggle" text="Label text"}}
        <div>
            <div class="btn btn-outline-secondary w-100 text-start d-flex justify-content-between align-items-center"
                    type="button"
                    id="multiSelectDropdownToggle"
                    aria-expanded="false">
                <span class="selected-values-text">({% trans "Nothing selected" %})</span>
                <i class="material-symbols-outlined" id="arrowIcon">expand_more</i>
            </div>
            <div class="dropdown-menu p-3 w-100 hide" id="multiSelectDropdownMenu">
                <div class="dropdownCheckboxesContainer">
                    <!-- Checkboxes will be dynamically added here -->
                </div>
                <div class="d-flex justify-content-between mt-2 border-top py-2 px-2">
                    <p class="values-count mb-0 text-darker-gray">0 {% trans "selected" %}</p>
                    {{> base/form/checkbox id="selectAllValues" text="Select All" bold=true}}
                </div>
            </div>
        </div>
        <button type="submit">submit</button>
        </form>

        <div id="chipContainer">
            <!-- Chips will be added here -->
        </div>
    </div>  
    {{/base/containers/html-container}}