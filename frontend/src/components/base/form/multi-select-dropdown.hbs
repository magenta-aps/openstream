{{> base/form/label for=dropdownBtnId text=labelText }}
<div class="position-relative">
    <div class="btn border-gray bg-white p-2 text-start d-flex justify-content-between align-items-center multiSelectDropdownToggle"
            type="button"
            id="{{dropdownBtnId}}"
            aria-expanded="false">
        <span class="selected-values-text">({% trans "Nothing selected" %})</span>
        <i class="material-symbols-outlined arrowIcon">expand_more</i>
    </div>
    <div class="dropdown-menu px-2 py-3 w-100 multiSelectDropdownMenu hide" id="{{dropdownMenuId}}">
        <div class="dropdownCheckboxesContainer">
            <!-- Checkboxes will be dynamically added here -->
        </div>
        <div class="d-flex justify-content-between mt-2 border-top py-2 px-2">
            <p class="values-count mb-0 text-darker-gray">0 {% trans "selected" %}</p>
            {{> base/form/checkbox id=selectAllCheckboxId class="selectAllValues" text="Select All" value="selectAll" }}
        </div>
    </div>
</div>