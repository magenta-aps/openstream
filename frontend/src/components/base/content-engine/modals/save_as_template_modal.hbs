{{#> base/modal/modal id="saveAsTemplateModal" ariaLabelledby="saveAsTemplateModalLabel" size="modal-xl" }}
    {{#*inline "header"}}
        {{> base/modal/modal-title title="Save Slide as Template" id="saveAsTemplateModalLabel"}}
        {{> base/modal/modal-header-close}}
    {{/inline}}

    {{#*inline "body"}}
        <form id="saveAsTemplateForm">
            <!-- NAME -->
            <div class="mb-3">
                {{> base/form/label for="templateName" text="Template Name"}}
                {{> base/form/input type="text" id="templateName" required=true}}
            </div>

            <!-- ASPECT RATIO -->
            <div class="mb-3 js-template-aspect-ratio-group">
                {{> base/form/label for="templateAspectRatio" text="Aspect Ratio"}}
                <p class="text-muted small mb-3">{% trans "Select the aspect ratio this template is designed for. The preview will automatically adjust to this aspect ratio." %}</p>

                <div class="card mb-2">
                    <div class="card-header py-2">
                        <h6 class="mb-0">{% trans "Landscape" %}</h6>
                    </div>
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-start align-items-end flex-wrap gap-2 js-template-aspect-ratio-options" data-orientation="landscape"></div>
                    </div>
                </div>

                <div class="card mb-2">
                    <div class="card-header py-2">
                        <h6 class="mb-0">{% trans "Portrait" %}</h6>
                    </div>
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-start align-items-end flex-wrap gap-2 js-template-aspect-ratio-options" data-orientation="portrait"></div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header py-2">
                        <h6 class="mb-0">{% trans "Square" %}</h6>
                    </div>
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-start align-items-end flex-wrap gap-2 js-template-aspect-ratio-options" data-orientation="square"></div>
                    </div>
                </div>

                {{> base/form/input type="hidden" id="templateAspectRatio" name="aspectRatio"}}
            </div>

            <div class="d-flex justify-content-between gap-4">
                <!-- CATEGORY -->
                <div class="mb-3 w-100">
                    {{> base/form/label for="templateCategory" text="Category"}}
                    <select class="form-select" id="templateCategory">
                        <!-- We'll programmatically add (None) and categories here -->
                    </select>
                </div>
                <!-- TAGS -->
                <div class="mb-3 w-100">
                    {{> base/form/multi-select-dropdown dropdownBtnId="tagsDropdownToggle" dropdownMenuId="tagsDropdownMenu" selectAllCheckboxId="selectAllTagsCheckbox" labelText="Tags"}}
                </div>
            </div>

            <div class="mb-3 d-none" id="globalTemplateThumbnailField">
                {{> base/form/label for="globalTemplateThumbnailInput" text="Global Template Thumbnail (optional)"}}
                <p class="text-muted small mb-2">{% trans "Upload a thumbnail image to help other editors recognize this global template. Images up to 1 MB are embedded as data URLs." %}</p>
                <div class="d-flex flex-column flex-lg-row gap-3 align-items-start">
                    <div class="ratio ratio-16x9 bg-body-secondary border rounded position-relative overflow-hidden w-100" style="max-width: 280px;" id="globalTemplateThumbnailPreview">
                        <img id="globalTemplateThumbnailPreviewImage" class="w-100 h-100 object-fit-contain d-none" alt="{% trans "Template thumbnail preview" %}" loading="lazy">
                        <span class="text-muted small position-absolute top-50 start-50 translate-middle text-center px-2" id="globalTemplateThumbnailPlaceholder">{% trans "No thumbnail selected." %}</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <label class="btn btn-outline-secondary mb-0" id="globalTemplateThumbnailUploadBtn">
                            <i class="material-symbols-outlined align-middle me-1">image</i>
                            {% trans "Choose Image" %}
                            <input type="file" class="visually-hidden" id="globalTemplateThumbnailInput" accept="image/*">
                        </label>
                        <button type="button" class="btn btn-outline-danger" id="clearGlobalTemplateThumbnailBtn">
                            <i class="material-symbols-outlined align-middle me-1">delete</i>
                            {% trans "Remove Thumbnail" %}
                        </button>
                    </div>
                </div>
            </div>

            {{> base/form/input type="hidden" id="templateOrgId"}}
        </form>
    {{/inline}}

    {{#*inline "footer"}}
        {{> base/modal/modal-footer-close btn-text="Cancel"}}
        {{> base/buttons/icon-button type='button' id='confirmSaveTemplateBtn' variant='primary' icon='save' text='Save'}}
    {{/inline}}
{{/base/modal/modal}}
