{{#> base/content-engine/element-type-toolbars/containers/element-type-toolbars-container class="tiptap-toolbar" title="text_fields" }}
    <div class="me-3 d-flex">
        {{#> base/form/dropdown id="" class="tiptap-font-family-select ms-1 me-3 form-select form-select-sm bg-transparent border-light-gray" }}
        <!-- Populated by JS -->
    {{/base/form/dropdown}}
        <div class="tiptap-font-size-controls d-flex align-items-center">
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapFontSizeDecreaseBtn"
            class="m-0 p-0" icon="remove" tooltip="{% trans 'Decrease Font Size' %}"}}
            
            <div class="dropdown mx-1">
                <div class="d-flex align-items-center border border-darker-gray rounded bg-transparent" style="width: 85px;">
                    <input type="number" class="tiptap-font-size-input form-control form-control-sm border-0 bg-transparent text-center p-0" 
                        style="width: 100%; -moz-appearance: textfield;" 
                        value="40">
                    <button class="btn btn-sm border-0 p-0 pe-1 text-dark" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="line-height: 0;" data-bs-popper-config='{"strategy":"fixed"}'>
                        <span class="material-symbols-outlined" style="font-size: 20px;">arrow_drop_down</span>
                    </button>
                    <ul class="dropdown-menu tiptap-font-size-dropdown-menu shadow" style="max-height: 500px; overflow-y: auto; min-width: 85px; width: 85px;">
                        <!-- Populated by JS -->
                    </ul>
                </div>
            </div>

            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapFontSizeIncreaseBtn"
            class="me-3 p-0" icon="add" tooltip="{% trans 'Increase Font Size' %}"}}
        </div>
        <div class="d-flex me-3" id="tiptapBasicFormattingGroup" data-toolbar-feature-group="basic-formatting">
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapBoldBtn" icon="format_bold"
            tooltip="{% trans 'Make Text Bold' %}" dataAttrs='data-feature="bold"'}}
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapItalicBtn"
            icon="format_italic" tooltip="{% trans 'Make Text Italic' %}" dataAttrs='data-feature="italic"'}}
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapUnderlineBtn"
            icon="format_underlined" tooltip="{% trans 'Underline Text' %}" dataAttrs='data-feature="underline"'}}
        </div>
        <div class="d-flex align-items-center me-3">
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapTextColorBtn"
            class="tiptap-text-color-picker" icon="format_color_text" tooltip="{% trans 'Change Text Color' %}"}}
        </div>
        <div class="d-flex me-3">
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapAlignTextLeftBtn"
            icon="format_align_left" tooltip="{% trans 'Align Text Left' %}"}}
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapAlignTextCenterBtn"
            icon="format_align_center" tooltip="{% trans 'Align Text Center' %}"}}
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapAlignTextRightBtn"
            icon="format_align_right" tooltip="{% trans 'Align Text Right' %}"}}
        </div>
        <div class="d-flex me-3">
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapAlignTopBtn"
            icon="vertical_align_top" tooltip="{% trans 'Align Top' %}"}}
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapAlignMiddleBtn"
            icon="vertical_align_center" tooltip="{% trans 'Align Middle' %}"}}
            {{> base/content-engine/element-type-toolbars/buttons/text-editor-btn id="tiptapAlignBottomBtn"
            icon="vertical_align_bottom" tooltip="{% trans 'Align Bottom' %}"}}
        </div>
        <div class="d-flex align-items-center">
            <span class="align-self-center material-symbols-outlined" role="img"
                aria-label="{% trans 'Line Height' %}" title="{% trans 'Line Height' %}">format_line_spacing</span>
            {{#> base/form/dropdown id="" class="tiptap-line-height-select form-select form-select-sm bg-transparent border-light-gray ms-2" title="{% trans 'Line Height' %}" }}
            {{> base/form/dropdown-option value="0.5" text="0.5"}}
            {{> base/form/dropdown-option value="0.6" text="0.6"}}
            {{> base/form/dropdown-option value="0.7" text="0.7"}}
            {{> base/form/dropdown-option value="0.8" text="0.8"}}
            {{> base/form/dropdown-option value="0.9" text="0.9"}}
            {{> base/form/dropdown-option value="1" text="1"}}
            {{> base/form/dropdown-option value="1.1" text="1.1"}}
            {{> base/form/dropdown-option value="1.2" text="1.2" selected=true}}
            {{> base/form/dropdown-option value="1.3" text="1.3"}}
            {{> base/form/dropdown-option value="1.4" text="1.4"}}
            {{> base/form/dropdown-option value="1.5" text="1.5"}}
            {{> base/form/dropdown-option value="1.6" text="1.6"}}
            {{> base/form/dropdown-option value="1.8" text="1.8"}}
            {{> base/form/dropdown-option value="2" text="2"}}
            {{> base/form/dropdown-option value="2.2" text="2.2"}}
            {{> base/form/dropdown-option value="2.5" text="2.5"}}
            {{> base/form/dropdown-option value="3" text="3"}}
        {{/base/form/dropdown}}
        </div>
    </div>
{{/base/content-engine/element-type-toolbars/containers/element-type-toolbars-container}}